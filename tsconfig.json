{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@services/*": ["./src/services/*"],
      "@context/*": ["./src/context/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@screens/*": ["./src/screens/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/types/**/*.d.ts", "index.js"],
  "exclude": ["node_modules", "macos/Pods", "ios/Pods"]
}
