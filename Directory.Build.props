<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    RNW native module builds invoke codegen-windows via MSBuild. The default
    CodegenCommand uses `npx @react-native-community/cli`, which does not load
    the react-native-windows CLI plugin and fails with:
      unknown command 'codegen-windows'
  -->
  <PropertyGroup>
    <CodegenCommand Condition="'$(CodegenCommand)' == ''">node &quot;$(MSBuildThisFileDirectory)node_modules\react-native\cli.js&quot; codegen-windows</CodegenCommand>
  </PropertyGroup>
</Project>
