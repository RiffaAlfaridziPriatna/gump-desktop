{
  "name": "GumpDesktop",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "ruby macos/scripts/patch_secure_text_field.rb",
    "start": "react-native start",
    "macos": "react-native run-macos",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest",
    "generate-schema": "node scripts/generate-schema.mjs",
    "build": "bash scripts/build.sh",
    "build:android": "bash scripts/build.sh android apk",
    "build:android:aab": "bash scripts/build.sh android aab",
    "build:ios": "bash scripts/build.sh ios ipa",
    "build:ios:archive": "bash scripts/build.sh ios archive",
    "build:macos": "bash scripts/build.sh macos app",
    "build:macos:zip": "bash scripts/build.sh macos zip",
    "build:windows": "node scripts/build-windows.mjs exe",
    "build:windows:msix": "node scripts/build-windows.mjs msix",
    "build:all": "bash scripts/build.sh all",
    "windows": "npx @react-native-community/cli run-windows",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/blur": "^4.4.1",
    "@react-native/new-app-screen": "0.81.6",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/stack": "^7.10.2",
    "immer": "^11.1.8",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-macos": "^0.81.7",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-windows": "^0.81.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.6",
    "@react-native/eslint-config": "0.81.6",
    "@react-native/metro-config": "0.81.6",
    "@react-native/typescript-config": "0.81.6",
    "@rnx-kit/jest-preset": "^0.1.17",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.4",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "openapi-typescript": "^6.7.6",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "GumpDesktop",
      "namespace": "GumpDesktop",
      "template": "cpp-app"
    }
  }
}
